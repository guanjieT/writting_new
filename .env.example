NOVEL_AGENT_NAME=Novel Agent Clean
NOVEL_AGENT_BASE_DIR=.
NOVEL_AGENT_DATA_DIR=./data
NOVEL_AGENT_PROMPTS_DIR=./prompts
NOVEL_AGENT_PROJECTS_DIR=./data/projects
NOVEL_AGENT_TASKS_DIR=./data/tasks
NOVEL_AGENT_AUDIT_LOG=./data/audit/events.jsonl
NOVEL_AGENT_HOST=127.0.0.1
NOVEL_AGENT_PORT=8001
NOVEL_AGENT_CORS_ALLOW_ORIGINS=*
NOVEL_AGENT_ENABLE_AUDIT=true

# LLM provider: mock | openai | openai-compatible | deepseek
NOVEL_AGENT_LLM_PROVIDER=deepseek
NOVEL_AGENT_LLM_API_KEY=
NOVEL_AGENT_LLM_BASE_URL=https://api.deepseek.com
NOVEL_AGENT_LLM_MODEL=deepseek-chat
NOVEL_AGENT_LLM_TIMEOUT=60
NOVEL_AGENT_DEFAULT_TEMPERATURE=0.7
NOVEL_AGENT_DEFAULT_MAX_TOKENS=1200

# Compatible aliases supported by config loader
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat